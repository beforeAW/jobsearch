generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  location    String?
  description String?
  applyUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
